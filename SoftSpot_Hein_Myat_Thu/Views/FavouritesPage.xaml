<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SoftSpot_Hein_Myat_Thu.Views.FavouritesPage"
    Title="Favourites"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="True">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20" >
        <VerticalStackLayout Grid.Row="0" Spacing="0">
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,0,0,12">
                <Label Text="❤️" FontSize="24"  VerticalOptions="Center" />
                <Label Text="Favourite Places"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" Margin="0,0,0,16" />
        </VerticalStackLayout>
        
        <!-- list of fav places -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding FavouritePlaces}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*" Padding="0,14" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="📍" FontSize="18" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Name}"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding BestTime, StringFormat='Usually quiet: {0}'}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                        </VerticalStackLayout>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.PlaceTappedCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- clear all button -->
        <Button Grid.Row="2"
                Text="Clear All"
                Command="{Binding ClearAllCommand}"
                HorizontalOptions="Center"
                Margin="0,16,0,24"
                BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray600}}"
                TextColor="{AppThemeBinding Light=Black, Dark={StaticResource Gray100}}"
                BorderColor="{AppThemeBinding Light=Black, Dark={StaticResource Gray300}}"
                BorderWidth="1"
                CornerRadius="8"
                Padding="24,12"
                FontAttributes="Bold" />
    </Grid>
</ContentPage>
    
