<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SoftSpot_Hein_Myat_Thu.Views.DetailsPage"
    Title="Place Details"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="*">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="0" HorizontalOptions="Fill">
                <HorizontalStackLayout Spacing="60" Margin="0,8,0,12">
                    <!-- back arrow and page title -->
                    <Button Text="⬅"
                    FontSize="24"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Gray100}}"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Start"
                    Padding="0,8,0,12" />
                    <Label Text="Place's Details" FontSize="24" FontAttributes="Bold" VerticalOptions="Center"/>
                </HorizontalStackLayout>


                <!-- Place name -->
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" Margin="0,0,0,12" />
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="50,8,50,12">
                    <Label Grid.Column="0" Text="📍" FontSize="20" VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding SelectedPlace.Name}"
                           FontSize="20"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           HorizontalOptions="StartAndExpand"
                           LineBreakMode="WordWrap"
                           MaxLines="2" />
                </Grid>

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" Margin="0,0,0,8" />

                <!-- place info -->
                <VerticalStackLayout Margin="30,4,30,0" Spacing="8">
                    <!-- location -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto">
                        <Label Grid.Column="0" Text="Location:" FontSize="16" VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="View on Map ↗"
                                HorizontalOptions="End"
                                VerticalOptions="Center"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Gray100}}"
                                Command="{Binding OpenMapCommand}"
                                FontSize="16" />
                    </Grid>

                    <!-- Noise level -->
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Noise Level:" VerticalOptions="Center" FontSize="16" />
                        <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End">
                            <Label Text="{Binding SelectedPlace.FilledNoiseDots, Converter={StaticResource IntToDotsConverter}}"
                                   FontSize="18"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Gray100}}"
                                   VerticalOptions="Center" />
                            <Label VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" FontSize="16">
                                <Label.Text>
                                    <Binding Path="SelectedPlace.NoiseLevel" StringFormat="({0})" />
                                </Label.Text>
                            </Label>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Crowd level -->
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Crowd Level:" VerticalOptions="Center" FontSize="16" />
                        <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End">
                            <Label Text="{Binding SelectedPlace.FilledCrowdDots, Converter={StaticResource IntToDotsConverter}}"
                                   FontSize="18"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Gray100}}"
                                   VerticalOptions="Center" />
                            <Label VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" FontSize="16">
                                <Label.Text>
                                    <Binding Path="SelectedPlace.CrowdLevel" StringFormat="({0})" />
                                </Label.Text>
                            </Label>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- wifi -->
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8" >
                        <Label Grid.Column="0" FontSize="16" Text="Wi-Fi:" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontSize="16"
                               HorizontalOptions="End"
                               Text="{Binding SelectedPlace.HasWifi, Converter={StaticResource BoolToWifiStringConverter}}"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Best time -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Grid.Column="0" FontSize="16" Text="Best Time:" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontSize="16"
                               HorizontalOptions="End"
                               Text="{Binding SelectedPlace.BestTime}"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Rating -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,8,0,4">
                        <Label Grid.Column="0" Text="Rating:" FontSize="16" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding SelectedPlace.DisplayStarCount, Converter={StaticResource IntToStarsStringConverter}}"
                               FontSize="16"
                               HorizontalOptions="End"
                               TextColor="#FFC107"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Description -->
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" Margin="0,16,0,12" />
                    <Label Text="Description:" FontSize="16" FontAttributes="Bold" Margin="0,8,0,4" />
                    <Label Text="{Binding SelectedPlace.Description}"
                           Margin="0,0,0,16"
                           FontSize="16" />
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" Margin="0,0,0,12" />

                </VerticalStackLayout>

                <!-- buttons -->
                <VerticalStackLayout Spacing="10" Margin="50,12,50,0" HorizontalOptions="Fill">
                    <Button Text="❤️ Save to Favourites"
                            HorizontalOptions="Fill"
                            Command="{Binding AddToFavouriteCommand}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
                            TextColor="{AppThemeBinding Light=Black, Dark={StaticResource Gray100}}"
                            BorderColor="{AppThemeBinding Light=Black, Dark={StaticResource Gray400}}"
                            BorderWidth="1"
                            CornerRadius="8"
                            Padding="14,12">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding SelectedPlace.IsFavorite}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="#E53935" />
                                <Setter Property="TextColor" Value="White" />
                                <Setter Property="BorderColor" Value="#C62828" />
                                <Setter Property="Text" Value="♥ Saved in Favourites" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Text="🔔 Notify when quiet"
                            HorizontalOptions="Fill"
                            Command="{Binding NotifyWhenQuietCommand}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
                            TextColor="{AppThemeBinding Light=Black, Dark={StaticResource Gray100}}"
                            BorderColor="{AppThemeBinding Light=Black, Dark={StaticResource Gray400}}"
                            BorderWidth="1"
                            CornerRadius="8"
                            Padding="14,12">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding NotifyWhenQuiet}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Primary}}" />
                                <Setter Property="TextColor" Value="White" />
                                <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Primary}}" />
                                <Setter Property="Text" Value="🔔 Quiet alert set" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>