<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SoftSpot_Hein_Myat_Thu"
             xmlns:converters="clr-namespace:SoftSpot_Hein_Myat_Thu.Converters"
             x:Class="SoftSpot_Hein_Myat_Thu.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:IntToStarsStringConverter x:Key="IntToStarsStringConverter" />
            <converters:IntToDotsConverter x:Key="IntToDotsConverter" />
            <converters:BoolToWifiStringConverter x:Key="BoolToWifiStringConverter" />
            <converters:UnreadNotiBackgroundCoverter x:Key="UnreadNotiBackgroundCoverter" />
            <converters:NotificationIconConverter x:Key="NotificationIconConverter" />
            <converters:DateTimeToRelativeTimeConverter x:Key="DateTimeToRelativeTimeConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>